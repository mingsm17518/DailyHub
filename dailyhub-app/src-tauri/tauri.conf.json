{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "日历日程管理",
  "version": "1.0.0",
  "identifier": "com.calendar.todolist",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "日历日程管理",
        "width": 1200,
        "height": 700,
        "minWidth": 900,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Calendar App",
    "copyright": "Copyright © 2025",
    "category": "Productivity",
    "shortDescription": "日历日程管理应用",
    "longDescription": "一个简单易用的日历日程管理应用，支持日程添加、待办事项管理等功能。"
  }
}
